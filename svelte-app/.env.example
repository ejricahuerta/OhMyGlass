# Google Maps API key for the store locator on /location
# Create a key at https://console.cloud.google.com/apis/credentials
# Enable "Maps JavaScript API" and optionally restrict the key by HTTP referrer (e.g. https://www.ohmyglass.ca/*)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Analytics / gtag measurement ID (e.g. G-XXXXXXXXXX). Must be PUBLIC_* to be available in the browser.
PUBLIC_GOOGLE_TAG_MANAGER_ID=

# PostHog project API key (project settings in PostHog). Must be PUBLIC_* to be available in the browser.
PUBLIC_POSTHOG_KEY=
# Optional: PostHog host (e.g. https://eu.i.posthog.com). Defaults to https://us.i.posthog.com
PUBLIC_POSTHOG_HOST=

# Google Business Profile sync (discover-gbp-ids.js, sync-gbp.js, gbp-auth.js load this file automatically)
# OAuth app credentials from Google Cloud (Desktop/Web app with business.manage scope)
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_REFRESH_TOKEN=
# Or put the token in keys.json: "gbp": { "refresh_token": "..." } (loaded automatically)
# Target GBP location (numeric Business Profile / listing id). Sync uses Business Information API v1.
GBP_LOCATION_ID=
# Optional — only needed for legacy v4 tools / discover:gbp account listing
# GBP_ACCOUNT_ID=
# Optional: provide direct token for ad-hoc runs instead of refresh flow
# GBP_ACCESS_TOKEN=
