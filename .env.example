# Google Maps API key for the store locator on /location
# Create a key at https://console.cloud.google.com/apis/credentials
# Enable "Maps JavaScript API" and optionally restrict the key by HTTP referrer (e.g. https://ohmyglass.ca/*)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Analytics / gtag measurement ID (e.g. G-XXXXXXXXXX). Must be PUBLIC_* to be available in the browser.
PUBLIC_GOOGLE_TAG_MANAGER_ID=

# PostHog project API key (project settings in PostHog). Must be PUBLIC_* to be available in the browser.
PUBLIC_POSTHOG_KEY=
# Optional: PostHog host (e.g. https://eu.i.posthog.com). Defaults to https://us.i.posthog.com
PUBLIC_POSTHOG_HOST=
